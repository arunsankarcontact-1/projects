replicaCount: 2

image:
  repository: nginx
  tag: latest

service:
  type: ClusterIP
  port: 80

serviceAccount:
  create: true
  name: ""

httpRoute:
  enabled: false

autoscaling:
  enabled: false

ingress:
  enabled: true
  className: nginx

  hosts:
    - host: myapp.local
      paths:
        - path: /
          pathType: Prefix

  annotations:
    nginx.ingress.kubernetes.io/rewrite-target: /
